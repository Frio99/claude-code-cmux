#!/bin/bash

export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# --- 弹窗报错 ---
alert() {
    osascript -e "display alert \"Claude Code Cmux\" message \"$1\" as warning"
    exit 1
}

# --- 获取目标目录 ---
TARGET_DIR="$1"
if [ -z "$TARGET_DIR" ]; then
    TARGET_DIR=$(osascript -e '
        tell application "Finder"
            try
                POSIX path of (target of front window as alias)
            on error
                ""
            end try
        end tell
    ')
fi
[ -z "$TARGET_DIR" ] && TARGET_DIR="$HOME"

# --- 检查目录是否存在 ---
[ ! -d "$TARGET_DIR" ] && alert "目录不存在: $TARGET_DIR"

# --- 找 claude 路径 ---
CLAUDE_PATH="$HOME/.local/bin/claude"
if [ ! -x "$CLAUDE_PATH" ]; then
    # fallback: 在常见路径中查找
    for p in /usr/local/bin/claude /opt/homebrew/bin/claude "$HOME/.npm-global/bin/claude"; do
        [ -x "$p" ] && CLAUDE_PATH="$p" && break
    done
fi
[ ! -x "$CLAUDE_PATH" ] && alert "找不到 Claude Code CLI\n\n请先安装: npm install -g @anthropic-ai/claude-code"

# --- 检查 cmux 是否已安装 ---
[ ! -d "/Applications/cmux.app" ] && alert "找不到 cmux\n\n请先安装: https://cmux.com"

# --- 找 cmux CLI ---
CMUX_CLI="/Applications/cmux.app/Contents/Resources/bin/cmux"
[ ! -x "$CMUX_CLI" ] && alert "找不到 cmux CLI\n\n请先安装: https://cmux.com"

# --- 确保 cmux socket 控制模式为 allowAll ---
CURRENT_MODE=$(defaults read com.cmuxterm.app socketControlMode 2>/dev/null)
if [ "$CURRENT_MODE" != "allowAll" ]; then
    defaults write com.cmuxterm.app socketControlMode -string allowAll
    # 如果 cmux 正在运行，需要重启才能生效
    if osascript -e 'application "cmux" is running' | grep -q true; then
        osascript -e 'tell application "cmux" to quit'
        sleep 1
    fi
fi

# --- 确保 cmux 运行并激活 ---
CMUX_WAS_RUNNING=$(osascript -e 'application "cmux" is running')
open -a cmux

# 等 cmux socket 就绪（最多 15s）
for i in $(seq 1 30); do
    "$CMUX_CLI" ping >/dev/null 2>&1 && break
    sleep 0.5
done
"$CMUX_CLI" ping >/dev/null 2>&1 || alert "cmux 启动超时，请手动打开 cmux 后重试"

# --- 创建 workspace 并启动 claude ---
WORKSPACE_NAME="Claude Code: $(basename "$TARGET_DIR")"

if [ "$CMUX_WAS_RUNNING" != "true" ]; then
    DEFAULT_WS=$("$CMUX_CLI" list-workspaces 2>/dev/null | head -1 | awk '{for(i=1;i<=NF;i++) if($i ~ /^workspace:/) {print $i; exit}}')
fi

NEW_WS=$("$CMUX_CLI" new-workspace --name "$WORKSPACE_NAME" --cwd "$TARGET_DIR" --command "'${CLAUDE_PATH}' --dangerously-skip-permissions")
NEW_WS="${NEW_WS#OK }"
"$CMUX_CLI" select-workspace --workspace "$NEW_WS"

if [ -n "$DEFAULT_WS" ]; then
    "$CMUX_CLI" close-workspace --workspace "$DEFAULT_WS" 2>/dev/null
fi
