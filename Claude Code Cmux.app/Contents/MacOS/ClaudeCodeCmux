#!/bin/bash

# 确保 UTF-8 编码，支持中文路径
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

TARGET_DIR="$1"

if [ -z "$TARGET_DIR" ]; then
    TARGET_DIR=$(osascript -e '
        tell application "Finder"
            try
                set currentPath to POSIX path of (target of front window as alias)
            on error
                set currentPath to ""
            end try
        end tell
    ')
fi

if [ -z "$TARGET_DIR" ]; then
    TARGET_DIR="$HOME"
fi

# 加载 shell 环境找到 claude 路径
source "$HOME/.zshrc" 2>/dev/null || true
export PATH="$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

CLAUDE_PATH=$(command -v claude 2>/dev/null)
if [ -z "$CLAUDE_PATH" ]; then
    CLAUDE_PATH="claude"
fi

CMD="cd '${TARGET_DIR}' && ${CLAUDE_PATH} --dangerously-skip-permissions"

# 检查 cmux 是否已在运行
CMUX_RUNNING=$(osascript -e 'application "cmux" is running')

# 保存剪贴板
OLD_CLIPBOARD=$(pbpaste 2>/dev/null)
echo -n "$CMD" | pbcopy

if [ "$CMUX_RUNNING" = "true" ]; then
    # 已运行，新建工作区，粘贴命令并回车
    osascript <<EOF
tell application "cmux" to activate
delay 0.3
tell application "System Events"
    tell process "cmux"
        keystroke "n" using command down
        delay 1
        keystroke "v" using command down
        delay 0.3
        key code 36
    end tell
end tell
EOF
else
    # 未运行，启动 cmux 并等待窗口就绪，使用默认工作区
    open -a cmux

    # 1) 等窗口出现（最多 15s）
    for i in $(seq 1 30); do
        WINDOW_COUNT=$(osascript -e 'tell application "cmux" to count of windows' 2>/dev/null)
        if [ "$WINDOW_COUNT" -gt 0 ] 2>/dev/null; then
            break
        fi
        sleep 0.5
    done

    # 2) 主动激活并轮询确认 cmux 已是最前台进程（最多 5s）
    osascript -e 'tell application "cmux" to activate' >/dev/null 2>&1
    for i in $(seq 1 25); do
        FRONT_APP=$(osascript -e 'tell application "System Events" to name of first application process whose frontmost is true' 2>/dev/null)
        if [ "$FRONT_APP" = "cmux" ]; then
            break
        fi
        osascript -e 'tell application "cmux" to activate' >/dev/null 2>&1
        sleep 0.2
    done

    # 3) 自适应等待：轮询 cmux 主窗口标题，连续两次相同且非空才认为 UI 已稳定
    #    （Electron 启动期间标题会从空 → "Loading..." → 真正的工作区名）
    PREV_TITLE=""
    STABLE_HITS=0
    for i in $(seq 1 40); do
        CUR_TITLE=$(osascript -e 'tell application "System Events" to tell process "cmux" to try
            return name of window 1
        on error
            return ""
        end try' 2>/dev/null)
        if [ -n "$CUR_TITLE" ] && [ "$CUR_TITLE" = "$PREV_TITLE" ]; then
            STABLE_HITS=$((STABLE_HITS + 1))
            if [ "$STABLE_HITS" -ge 2 ]; then
                break
            fi
        else
            STABLE_HITS=0
        fi
        PREV_TITLE="$CUR_TITLE"
        sleep 0.2
    done

    osascript <<EOF
tell application "cmux" to activate
delay 0.3
tell application "System Events"
    tell process "cmux"
        keystroke "v" using command down
        delay 0.5
        key code 36
    end tell
end tell
EOF
fi

# 恢复剪贴板
sleep 1
echo -n "$OLD_CLIPBOARD" | pbcopy
